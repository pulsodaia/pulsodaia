    { "name": "DLV - error_status", "type": "dataLayerVar", "key": "error_status" }
  ],

  "triggers": [
    {
      "id_ref": "pulso_custom_events",
      "name": "Pulso - Custom Events (regex)",
      "type": "customEvent",
      "event_regex": "^(article_|newsletter_|nav_|theme_|web_vital_|outbound_|tag_|share_|related_|source_|feed_|logo_|breadcrumb_|cta_|whatsapp_).+|^(js_error|unhandled_rejection|resource_error)$"
    }
  ],

  "tags": [
    {
      "name": "GA4 Configuration",
      "type": "googtag",
      "trigger": "ALL_PAGES",
      "params": { "tagId": "{{GA4 Measurement ID}}" }
    },
    {
      "name": "GA4 Event - Catch-All",
      "type": "gaawe",
      "trigger": "pulso_custom_events",
      "event_name": "{{Event}}",
      "event_params": [
        { "name": "article_slug", "value": "{{DLV - article_slug}}" },
        { "name": "article_category", "value": "{{DLV - article_category}}" },
        { "name": "article_source", "value": "{{DLV - article_source}}" },
        { "name": "article_headline", "value": "{{DLV - article_headline}}" },
        { "name": "article_read_time", "value": "{{DLV - article_read_time}}" },
        { "name": "article_word_count", "value": "{{DLV - article_word_count}}" },
        { "name": "to_slug", "value": "{{DLV - to_slug}}" },
        { "name": "to_category", "value": "{{DLV - to_category}}" },
        { "name": "card_position", "value": "{{DLV - card_position}}" },
        { "name": "source_domain", "value": "{{DLV - source_domain}}" },
        { "name": "share_channel", "value": "{{DLV - share_channel}}" },
        { "name": "tag_name", "value": "{{DLV - tag_name}}" },
        { "name": "newsletter_source", "value": "{{DLV - newsletter_source}}" },
        { "name": "dropdown_name", "value": "{{DLV - dropdown_name}}" },
        { "name": "category_name", "value": "{{DLV - category_name}}" },
        { "name": "filter_category", "value": "{{DLV - filter_category}}" },
        { "name": "theme_to", "value": "{{DLV - theme_to}}" },
        { "name": "cta_location", "value": "{{DLV - cta_location}}" },
        { "name": "outbound_url", "value": "{{DLV - outbound_url}}" },
        { "name": "outbound_domain", "value": "{{DLV - outbound_domain}}" },
        { "name": "web_vital_value", "value": "{{DLV - web_vital_value}}" },
        { "name": "web_vital_rating", "value": "{{DLV - web_vital_rating}}" },
        { "name": "error_message", "value": "{{DLV - error_message}}" },
        { "name": "error_source", "value": "{{DLV - error_source}}" },
        { "name": "error_status", "value": "{{DLV - error_status}}" }
      ]
    }
  ],

  "ga4_conversions_only": [

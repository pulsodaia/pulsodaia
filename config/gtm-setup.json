{
  "_comment": "Config declarativa GTM+GA4. Replicar em outro cliente: trocar IDs em client/gtm/ga4 e rodar `node scripts/setup-gtm-ga4.js --config config/{cliente}.json --publish --cleanup`. O --cleanup apaga tags/triggers/vars que NAO estao neste config (by name).",

  "client": {
    "name": "Pulso da IA",
    "domain": "pulsodaia.com.br"
  },

  "gtm": {
    "account_id": "6305486821",
    "account_name": "GTM - TRIADEFLOW",
    "container_id": "249877205",
    "container_public_id": "GTM-MXGJBNFB",
    "container_name": "Pulso da IA",
    "workspace_name": "Default Workspace",
    "version_prefix": "autopilot"
  },

  "ga4": {
    "account_id": "391895069",
    "property_id": "533692705",
    "measurement_id": "G-32GWZHPJGJ",
    "stream_id": "14397320891",
    "stream_url": "https://pulsodaia.com.br"
  },

  "builtin_variables": [
    "clickClasses", "clickUrl", "clickElement", "clickTarget", "clickText", "clickId",

    { "name": "DLV - article_word_count", "type": "dataLayerVar", "key": "article_word_count" },
    { "name": "DLV - to_slug", "type": "dataLayerVar", "key": "to_slug" },
    { "name": "DLV - to_category", "type": "dataLayerVar", "key": "to_category" },

    { "name": "DLV - tag_name", "type": "dataLayerVar", "key": "tag_name" },
    { "name": "DLV - newsletter_source", "type": "dataLayerVar", "key": "newsletter_source" },
    { "name": "DLV - dropdown_name", "type": "dataLayerVar", "key": "dropdown_name" },
    { "name": "DLV - category_name", "type": "dataLayerVar", "key": "category_name" },
    { "name": "DLV - filter_category", "type": "dataLayerVar", "key": "filter_category" },
    { "name": "DLV - theme_to", "type": "dataLayerVar", "key": "theme_to" },
    { "name": "DLV - cta_location", "type": "dataLayerVar", "key": "cta_location" },
    { "name": "DLV - outbound_url", "type": "dataLayerVar", "key": "outbound_url" },
    { "name": "DLV - outbound_domain", "type": "dataLayerVar", "key": "outbound_domain" },
